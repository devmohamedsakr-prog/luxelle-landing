modules = ["web", "nodejs-20", "dotnet-7.0", "dotnet-8.0"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && ../node_modules/.bin/ng serve --host 0.0.0.0 --port 5000 --allowed-hosts all"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && dotnet run --project src/Luxelle.API/Luxelle.API.csproj"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && dotnet run --project src/Luxelle.API/Luxelle.API.csproj & cd frontend && npx http-server dist/luxelle-landing-page -p 5000 --proxy http://localhost:5000?"]
build = ["bash", "-c", "cd frontend && npm install --legacy-peer-deps && npm run build:prod"]
